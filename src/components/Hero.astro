---
import { artist, hero, theme } from "../config/artist";
import NavLinks from "./NavLinks.astro";
import SocialIcons from "./SocialIcons.astro";
import ParticleCanvas from "./ParticleCanvas";

const hasImage = hero.backgroundImage != null && hero.backgroundImage.trim() !== "";
const hasLogotype = artist.logotype != null && artist.logotype.trim() !== "";
---

<section class="hero" id="home">
  <!-- Background layers (fixed) — image and animation can coexist -->
  {hasImage && (
    <div class="hero__bg hero__bg--image" style={`background-image: url('${hero.backgroundImage}')`} aria-hidden="true" />
  )}
  {hero.animationEnabled && (
    <div class="hero__bg hero__bg--canvas" aria-hidden="true">
      <ParticleCanvas color={hero.particleColor || theme.accentColor} client:only="react" />
    </div>
  )}

  <!-- Fixed center content: logotype + nav -->
  <div class="hero__center" id="hero-center">
    {hasLogotype ? (
      <img src={artist.logotype!} alt={`${artist.name} logo`} class="hero__logotype" width="400" height="120" />
    ) : (
      <h1 class="hero__title">{artist.name}</h1>
    )}
    <NavLinks class="hero__nav" linkColor={hero.navAndSocialColor} />
  </div>

  <!-- Bottom row: social icons (scrolls with page) -->
  <div class="hero__bottom">
    <SocialIcons size={20} iconColor={hero.navAndSocialColor} />
  </div>
</section>

<script>
  function initHeroScroll() {
    const center = document.getElementById("hero-center");
    if (!center) return;

    let ticking = false;

    function update() {
      const scrollY = window.scrollY;
      const vh =
        window.visualViewport?.height ?? window.innerHeight;
      const progress = Math.min(scrollY / (vh * 0.5), 1);
      const opacity = 1 - progress;

      center!.style.opacity = String(opacity);
      center!.style.pointerEvents = opacity <= 0 ? "none" : "auto";
      center!.style.visibility = opacity <= 0 ? "hidden" : "visible";
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
        ticking = true;
      }
    }

    update();
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  initHeroScroll();
</script>

<style>
  .hero {
    position: relative;
    /* 100vh is often taller than the visible area on mobile (URL bar), hiding bottom content.
       svh/dvh match the actual viewport better. */
    height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Fixed background layers — canvas renders above image when both are present */
  .hero__bg {
    position: fixed;
    inset: 0;
  }

  .hero__bg--image {
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero__bg--canvas {
    z-index: 1;
    pointer-events: none;
  }

  /* Fixed centered content — starts hidden to prevent flash; JS sets correct opacity immediately */
  .hero__center {
    position: fixed;
    top: clamp(6%, 10vh, 12%);
    left: 0;
    right: 0;
    width: 100%;
    box-sizing: border-box;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    will-change: opacity;
  }

  /* Inset nav from viewport edges on narrow screens when many links wrap */
  .hero :global(.hero__nav) {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    padding-left: max(clamp(0.75rem, 6.5vw, 2rem), env(safe-area-inset-left, 0px));
    padding-right: max(clamp(0.75rem, 6.5vw, 2rem), env(safe-area-inset-right, 0px));
  }

  .hero__logotype {
    max-width: min(85vw, 500px);
    height: auto;
    object-fit: contain;
  }

  .hero :global(.nav-links__list) {
    gap: clamp(0.75rem, 3vw, 2rem);
  }

  .hero :global(.nav-links__link) {
    font-size: clamp(0.55rem, 2.1vw + 0.35rem, 0.8rem);
    letter-spacing: clamp(0.1em, 0.5vw + 0.1em, 0.2em);
  }

  .hero__title {
    font-size: clamp(2rem, 9vw + 0.5rem, 7rem);
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1;
  }

  /* Bottom social icons - scrolls with the hero section */
  .hero__bottom {
    position: absolute;
    bottom: max(2rem, env(safe-area-inset-bottom, 0px));
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    padding-inline: 0.5rem;
  }

  .hero__bottom :global(.social-icons) {
    gap: clamp(0.65rem, 3vw, 1.25rem);
  }

  @media (max-width: 640px) {
    .hero__title {
      font-size: clamp(1.75rem, 10vw + 0.25rem, 4rem);
    }

    .hero__logotype {
      width: clamp(8rem, 58vw, 18rem);
    }
  }
</style>
